generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccessStatus {
  PENDING
  APPROVED
  DECLINED
  WAITLISTED
}

enum UserRole {
  MEMBER
  ADMIN
}

enum ReservationStatus {
  REQUESTED
  CONFIRMED
  WAITLISTED
  CANCELLATION_REQUESTED
  CANCELLED
}

enum ReferralStatus {
  SENT
  REQUESTED
  APPROVED
  DECLINED
}

enum EmailStatus {
  SENT
  FAILED
  SKIPPED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  POSTPONED
  CANCELLED
  ARCHIVED
}

enum EventVisibility {
  ALL_MEMBERS
  SELECTED_MEMBERS
  INVITE_ONLY
}

enum FeedbackCategory {
  EXPERIENCE_FEEDBACK
  PRODUCT_FEEDBACK
  TECHNICAL_ISSUE
  SUGGESTION
  GENERAL_MESSAGE
}

enum FeedbackStatus {
  OPEN
  UNDER_REVIEW
  REPLIED
  CLOSED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  emailVerified       Boolean              @default(false)
  fullName            String
  avatarUrl           String?
  passwordHash        String?
  passwordSetAt       DateTime?
  suspendedAt         DateTime?
  accessStatus        AccessStatus         @default(PENDING)
  role                UserRole             @default(MEMBER)
  referredBy          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  accounts            Account[]
  passwordSetupTokens PasswordSetupToken[]
  passwordResetTokens PasswordResetToken[]
  reservations        Reservation[]
  referrals           Referral[]
  selectedExperiences ExperienceAudienceMember[]
  feedbackThreads     FeedbackThread[]
  feedbackMessages    FeedbackMessage[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model AccessRequest {
  id                   String       @id @default(cuid())
  fullName             String
  email                String
  phone                String
  referredBy           String?
  interests            String[]
  preferredExperiences String[]
  message              String
  status               AccessStatus @default(PENDING)
  reviewedAt           DateTime?
  reviewedById         String?
  adminNote            String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([email])
  @@index([status])
}

model Experience {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  location      String
  dateTime      DateTime
  imageUrl      String
  hostedByLabel String
  hostName      String
  hostTitle     String?
  hostBio       String?
  seatsTotal    Int?
  isVisible     Boolean       @default(true)
  isInviteOnly  Boolean       @default(true)
  isArchived    Boolean       @default(false)
  status        EventStatus   @default(PUBLISHED)
  publishedAt   DateTime?
  announcementSentAt DateTime?
  postponedAt   DateTime?
  cancelledAt   DateTime?
  cancellationReason String?
  postponementMessage String?
  visibilityType EventVisibility @default(ALL_MEMBERS)
  attendeeVisibilityEnabled Boolean @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  reservations  Reservation[]
  audienceMembers ExperienceAudienceMember[]

  @@index([isVisible])
  @@index([isArchived])
  @@index([status])
  @@index([visibilityType])
  @@index([dateTime])
}

model Reservation {
  id                      String            @id @default(cuid())
  userId                  String
  experienceId            String
  status                  ReservationStatus @default(REQUESTED)
  cancellationRequestedAt DateTime?
  cancellationReason      String?
  cancellationNote        String?
  previousStatus          ReservationStatus?
  adminCancellationReply  String?
  createdAt               DateTime          @default(now())
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience              Experience        @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([userId, experienceId])
  @@index([status])
  @@index([experienceId, status])
}

model ExperienceAudienceMember {
  id           String     @id @default(cuid())
  experienceId String
  userId       String
  invitedAt    DateTime   @default(now())
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([experienceId, userId])
  @@index([userId])
}

model Referral {
  id            String         @id @default(cuid())
  referrerId    String
  referredName  String
  referredEmail String
  relationship  String
  note          String?
  status        ReferralStatus @default(SENT)
  createdAt     DateTime       @default(now())
  referrer      User           @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referredEmail])
}

model EmailLog {
  id                String      @id @default(cuid())
  toEmail           String
  templateKey       String
  status            EmailStatus
  providerMessageId String?
  createdAt         DateTime    @default(now())

  @@index([toEmail])
  @@index([templateKey])
}

model PasswordSetupToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminNote {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  note       String
  createdBy  String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model FeedbackThread {
  id        String           @id @default(cuid())
  userId    String
  category  FeedbackCategory
  subject   String
  status    FeedbackStatus   @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  FeedbackMessage[]

  @@index([userId])
  @@index([status])
  @@index([category])
}

model FeedbackMessage {
  id        String         @id @default(cuid())
  threadId  String
  senderId  String?
  isAdmin   Boolean        @default(false)
  message   String
  createdAt DateTime       @default(now())
  thread    FeedbackThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User?          @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([senderId])
}
